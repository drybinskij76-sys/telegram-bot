draw.text((250, 175), "0,00", fill="black", font=f_sum)        # удержано
    draw.text((430, 175), amount_fmt, fill="black", font=f_sum)    # остаток

    # --- Комментарий (с переносами) ---
    # Верхняя точка комментария
    x_comment, y_comment = 35, 385
    max_width = img.size[0] - 70
    lines = wrap_text(draw, comment, f_comment, max_width=max_width)
    for i, line in enumerate(lines[:4]):  # максимум 4 строки
        draw.text((x_comment, y_comment + i * 22), line, fill="black", font=f_comment)

    # --- Дата ---
    draw.text((35, 485), date_now, fill="black", font=f_comment)

    bio = BytesIO()
    bio.name = "result.png"
    img.save(bio, "PNG")
    bio.seek(0)
    return bio


# =========================
#  Telegram handlers
# =========================
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("Привет! Команда /new — создать удержание.\n/cancel — отмена.")


async def new(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data.clear()
    await update.message.reply_text("Введите ФИО:")
    return FIO


async def get_fio(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["fio"] = update.message.text.strip()
    await update.message.reply_text("Введите сумму (например: 5000 или 5 000,00):")
    return SUM


async def get_sum(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["sum"] = update.message.text.strip()
    await update.message.reply_text("Введите комментарий:")
    return COMMENT


async def get_comment(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["comment"] = update.message.text.strip()
    await update.message.reply_text("Введите инициалы (например: СД):")
    return INITIALS


async def get_initials(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["initials"] = update.message.text.strip()

    fio = context.user_data.get("fio", "")
    amount = context.user_data.get("sum", "")
    comment = context.user_data.get("comment", "")
    initials = context.user_data.get("initials", "")

    try:
        img = render_card(fio, amount, comment, initials)
        await update.message.reply_photo(photo=img, caption="Готово ✅\n/new — сделать ещё раз")
    except Exception as e:
        await update.message.reply_text(f"Ошибка генерации: {e}")

    return ConversationHandler.END


async def cancel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("Ок, отменено. /new — начать заново.")
    return ConversationHandler.END


# =========================
#  Main
# =========================
def main():
    token = os.getenv("BOT_TOKEN")
    if not token:
        raise RuntimeError("BOT_TOKEN не задан. Railway → Variables → BOT_TOKEN")

    # Запускаем веб-сервер для Railway
    threading.Thread(target=run_web_server, daemon=True).start()

    app = Application.builder().token(token).build()

    # ВАЖНО: выключаем webhook, чтобы polling точно работал
    async def post_init(application: Application):
        await application.bot.delete_webhook(drop_pending_updates=True)

    app.post_init = post_init

    conv = ConversationHandler(
        entry_points=[CommandHandler("new", new)],
        states={
            FIO: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_fio)],
            SUM: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_sum)],
            COMMENT: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_comment)],
            INITIALS: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_initials)],
        },
        fallbacks=[CommandHandler("cancel", cancel)],
    )

    app.add_handler(CommandHandler("start", start))
    app.add_handler(conv)

    print("BOT STARTED")
    app.run_polling()


if __name__ == "__main__":
    main()