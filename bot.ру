import os
import re
import threading
from io import BytesIO
from datetime import datetime
from http.server import BaseHTTPRequestHandler, HTTPServer

from PIL import Image, ImageDraw, ImageFont
from telegram import Update
from telegram.ext import (
    Application,
    CommandHandler,
    MessageHandler,
    ConversationHandler,
    ContextTypes,
    filters,
)

# --- Диалоговые состояния ---
FIO, SUM, COMMENT, INITIALS = range(4)

# --- Файл-шаблон (лежит рядом с bot.py) ---
TEMPLATE_PATH = "депрем.png"


# =========================
#  Railway: простой HTTP сервер, чтобы сервис не "умирал"
# =========================
def run_web_server():
    port = int(os.getenv("PORT", "8080"))

    class Handler(BaseHTTPRequestHandler):
        def do_GET(self):
            self.send_response(200)
            self.end_headers()
            self.wfile.write(b"Bot is running")

        def log_message(self, format, *args):
            # чтобы не засорять логи
            return

    server = HTTPServer(("0.0.0.0", port), Handler)
    server.serve_forever()


# =========================
#  Вспомогательные функции
# =========================
def load_font(size: int, bold: bool = False) -> ImageFont.FreeTypeFont:
    """
    Пытаемся загрузить нормальный шрифт.
    В Docker (python:slim) DejaVu обычно есть; если нет — будет default.
    """
    candidates = [
        "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf" if bold else "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf",
        "/usr/share/fonts/truetype/liberation/LiberationSans-Bold.ttf" if bold else "/usr/share/fonts/truetype/liberation/LiberationSans-Regular.ttf",
    ]
    for path in candidates:
        try:
            return ImageFont.truetype(path, size=size)
        except Exception:
            pass
    return ImageFont.load_default()


def format_sum(text: str) -> str:
    """
    Приводим ввод к виду "5 000,00" по возможности.
    """
    raw = text.strip()
    cleaned = re.sub(r"[^0-9,\.]", "", raw)
    if not cleaned:
        return raw

    cleaned = cleaned.replace(",", ".")
    try:
        val = float(cleaned)
    except Exception:
        return raw

    rub = int(val)
    kop = int(round((val - rub) * 100))
    if kop == 100:
        rub += 1
        kop = 0

    rub_str = f"{rub:,}".replace(",", " ")
    return f"{rub_str},{kop:02d}"


def wrap_text(draw: ImageDraw.ImageDraw, text: str, font: ImageFont.FreeTypeFont, max_width: int):
    """
    Перенос текста по словам под заданную ширину.
    """
    words = text.split()
    lines = []
    cur = ""
    for w in words:
        test = (cur + " " + w).strip()
        if draw.textlength(test, font=font) <= max_width:
            cur = test
        else:
            if cur:
                lines.append(cur)
            cur = w
    if cur:
        lines.append(cur)
    return lines


def render_card(fio: str, amount: str, comment: str, initials: str) -> BytesIO:
    """
    Рисуем поверх TEMPLATE_PATH и возвращаем PNG в памяти.
    Координаты под твой скрин; если нужно идеально — можно подправить 2-3 числа.
    """
    if not os.path.exists(TEMPLATE_PATH):
        raise FileNotFoundError(f"Не найден шаблон: {TEMPLATE_PATH}. Положи его рядом с bot.py")

    amount_fmt = format_sum(amount)
    initials = (initials or "").strip().upper()[:3]
    date_now = datetime.now().strftime("%d.%m.%y")

    img = Image.open(TEMPLATE_PATH).convert("RGB")
    draw = ImageDraw.Draw(img)

    # --- Шрифты ---
    f_init = load_font(30, bold=True)
    f_fio = load_font(22, bold=True)
    f_sum = load_font(20, bold=True)
    f_comment = load_font(16, bold=False)

    # --- Инициалы (круг слева) ---
    # Подогнано под твой шаблон. Если не по центру — подвинем.
    draw.text((48, 58), initials, fill="white", font=f_init)

    # --- ФИО ---
    draw.text((120, 45), fio, fill="black", font=f_fio)

    # --- Суммы (3 колонки) ---
    draw.text((55, 175), amount_fmt, fill="black", font=f_sum)     # сумма
    draw.text((250, 175), "0,00", fill="black", font=f_sum)        # удержано
    draw.text((430, 175), amount_fmt, fill="black", font=f_sum)    # остаток

    # --- Комментарий (с переносами) ---
    # Верхняя точка комментария
    x_comment, y_comment = 35, 385
    max_width = img.size[0] - 70
    lines = wrap_text(draw, comment, f_comment, max_width=max_width)
    for i, line in enumerate(lines[:4]):  # максимум 4 строки
        draw.text((x_comment, y_comment + i * 22), line, fill="black", font=f_comment)

    # --- Дата ---
    draw.text((35, 485), date_now, fill="black", font=f_comment)

    bio = BytesIO()
    bio.name = "result.png"
    img.save(bio, "PNG")
    bio.seek(0)
    return bio


# =========================
#  Telegram handlers
# =========================
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("Привет! Команда /new — создать удержание.\n/cancel — отмена.")


async def new(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data.clear()
    await update.message.reply_text("Введите ФИО:")
    return FIO


async def get_fio(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["fio"] = update.message.text.strip()
    await update.message.reply_text("Введите сумму (например: 5000 или 5 000,00):")
    return SUM


async def get_sum(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["sum"] = update.message.text.strip()
    await update.message.reply_text("Введите комментарий:")
    return COMMENT


async def get_comment(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["comment"] = update.message.text.strip()
    await update.message.reply_text("Введите инициалы (например: СД):")
    return INITIALS


async def get_initials(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["initials"] = update.message.text.strip()

    fio = context.user_data.get("fio", "")
    amount = context.user_data.get("sum", "")
    comment = context.user_data.get("comment", "")
    initials = context.user_data.get("initials", "")

    try:
        img = render_card(fio, amount, comment, initials)
        await update.message.reply_photo(photo=img, caption="Готово ✅\n/new — сделать ещё раз")
    except Exception as e:
        await update.message.reply_text(f"Ошибка генерации: {e}")

    return ConversationHandler.END


async def cancel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("Ок, отменено. /new — начать заново.")
    return ConversationHandler.END


# =========================
#  Main
# =========================
def main():
    token = os.getenv("BOT_TOKEN")
    if not token:
        raise RuntimeError("BOT_TOKEN не задан. Railway → Variables → BOT_TOKEN")

    # Запускаем веб-сервер для Railway
    threading.Thread(target=run_web_server, daemon=True).start()

    app = Application.builder().token(token).build()

    # ВАЖНО: выключаем webhook, чтобы polling точно работал
    async def post_init(application: Application):
        await application.bot.delete_webhook(drop_pending_updates=True)

    app.post_init = post_init

    conv = ConversationHandler(
        entry_points=[CommandHandler("new", new)],
        states={
            FIO: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_fio)],
            SUM: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_sum)],
            COMMENT: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_comment)],
            INITIALS: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_initials)],
        },
        fallbacks=[CommandHandler("cancel", cancel)],
    )

    app.add_handler(CommandHandler("start", start))
    app.add_handler(conv)

    print("BOT STARTED")
    app.run_polling()


if __name__ == "__main__":
    main()
